root = true

# ── Base: applies repo-wide ───────────────────────────────────────────────
[*.cs]
indent_style = space
indent_size = 4
tab_width = 4
charset = utf-8
insert_final_newline = true

# Never `var` — always the explicit type.
csharp_style_var_for_built_in_types = false:warning
csharp_style_var_when_type_is_apparent = false:warning
csharp_style_var_elsewhere = false:warning

# ── Peter's style — scoped to the ScepWright suite ────────────────────────
# The IntuneSimulator deliberately keeps its modern .NET idioms; these rules
# apply only to the ScepWright projects (shared libs + client + server + tests).
[{src/ScepWright.Crypto,src/ScepWright.Crypto.BouncyCastle,src/ScepWright.Core,src/ScepWright.Client,src/ScepWright.Server,src/ScepWright.Server.Host,src/ScepWright.Dispatcher,tests/ScepWright.Tests}/**.cs]

# --- Brace style: same line, not Allman ---
csharp_new_line_before_open_brace = none
csharp_new_line_before_else = false
csharp_new_line_before_catch = false
csharp_new_line_before_finally = false
csharp_new_line_before_members_in_object_initializers = false
csharp_new_line_before_members_in_anonymous_types = false
csharp_new_line_between_query_expression_clauses = false

# --- Always brace single-statement blocks (no unbraced if/for/while/foreach) ---
csharp_prefer_braces = true:warning

# --- No LINQ-style suggestions ---
dotnet_diagnostic.IDE0057.severity = none
csharp_style_prefer_switch_expression = false
csharp_style_prefer_pattern_matching = false

# --- Misc spacing ---
csharp_space_after_keywords_in_control_flow_statements = true
csharp_space_between_method_declaration_parameter_list_parentheses = false
csharp_space_between_method_call_parameter_list_parentheses = false

# --- Naming: methods/types PascalCase; const + static-readonly PascalCase;
#     private instance fields _snake_case; locals/parameters snake_case ---
dotnet_naming_style.pascal_style.capitalization = pascal_case

dotnet_naming_style.snake_style.capitalization = all_lower
dotnet_naming_style.snake_style.word_separator = _

dotnet_naming_style.underscore_snake_style.capitalization = all_lower
dotnet_naming_style.underscore_snake_style.word_separator = _
dotnet_naming_style.underscore_snake_style.required_prefix = _

dotnet_naming_symbols.method_symbols.applicable_kinds = method
dotnet_naming_symbols.method_symbols.applicable_accessibilities = *
dotnet_naming_rule.methods_pascal.symbols = method_symbols
dotnet_naming_rule.methods_pascal.style = pascal_style
dotnet_naming_rule.methods_pascal.severity = warning

# const + static readonly named constants stay PascalCase (more specific than the field rule).
dotnet_naming_symbols.const_symbols.applicable_kinds = field
dotnet_naming_symbols.const_symbols.applicable_accessibilities = *
dotnet_naming_symbols.const_symbols.required_modifiers = const
dotnet_naming_rule.const_pascal.symbols = const_symbols
dotnet_naming_rule.const_pascal.style = pascal_style
dotnet_naming_rule.const_pascal.severity = warning

dotnet_naming_symbols.static_readonly_symbols.applicable_kinds = field
dotnet_naming_symbols.static_readonly_symbols.applicable_accessibilities = *
dotnet_naming_symbols.static_readonly_symbols.required_modifiers = static, readonly
dotnet_naming_rule.static_readonly_pascal.symbols = static_readonly_symbols
dotnet_naming_rule.static_readonly_pascal.style = pascal_style
dotnet_naming_rule.static_readonly_pascal.severity = warning

# all other fields (private instance state) are _snake_case.
dotnet_naming_symbols.field_symbols.applicable_kinds = field
dotnet_naming_symbols.field_symbols.applicable_accessibilities = *
dotnet_naming_rule.fields_snake.symbols = field_symbols
dotnet_naming_rule.fields_snake.style = underscore_snake_style
dotnet_naming_rule.fields_snake.severity = warning

dotnet_naming_symbols.local_symbols.applicable_kinds = local, parameter
dotnet_naming_symbols.local_symbols.applicable_accessibilities = *
dotnet_naming_rule.locals_snake.symbols = local_symbols
dotnet_naming_rule.locals_snake.style = snake_style
dotnet_naming_rule.locals_snake.severity = warning

# ── Tests: xUnit method names keep their Word_word_word form ───────────────
[tests/ScepWright.Tests/**.cs]
dotnet_naming_rule.methods_pascal.severity = none
